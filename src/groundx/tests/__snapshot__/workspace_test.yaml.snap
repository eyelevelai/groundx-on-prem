  10: |
    apiVersion: v1
    data:
      config.py: |
        from pathlib import Path

        from settings import Settings


        settings = Settings(
            allowed_commands="python,git",
            celery_broker_url="redis://external-cache.example.com:6379/3",
            celery_global_keyprefix="{workspace-test}",
            celery_result_backend="redis://external-cache.example.com:6379/4",
            celery_task_always_eager=False,
            celery_task_soft_time_limit_seconds=600,
            command_timeout_seconds=180,
            git_provider="github",
            github_api_base_url="https://api.github.com",
            github_app_id="",
            github_app_installation_id="",
            github_app_private_key_path="",
            github_app_private_key_pem="",
            github_token_ttl_seconds=3600,
            gitlab_api_base_url="https://gitlab.com/api/v4",
            gitlab_token="",
            gitlab_token_path="",
            managed_repo_name_prefix="workspace-test",
            managed_repo_owner="GroundX-Studio",
            managed_repo_visibility="private",
            mysql_connect_timeout_seconds=20,
            mysql_database="eyelevel",
            mysql_host="db-cluster-haproxy.eyelevel.svc.cluster.local",
            mysql_password="",
            mysql_port=3306,
            mysql_username="",
            publish_dry_run=True,
            runner_token="test-runner-token",
            service="workspace",
            workspace_min_free_bytes=1.048576e+06,
            workspace_min_free_percent=5,
            workspace_root=Path("/mnt/workspaces"),
        )
    kind: ConfigMap
    metadata:
      labels:
        appVersion: 0.1.0
        chart: groundx-0.1.0
        heritage: Helm
        version: 0.1.0
      name: workspace-config-py-map
      namespace: eyelevel
  11: |
    apiVersion: v1
    data:
      gunicorn_conf.py: |
        accesslog = "-"
        errorlog = "-"
        loglevel = "info"
        timeout = 180
        timeout_keep_alive = 20
        worker_class = "uvicorn.workers.UvicornWorker"
        workers = 2
        threads = 2
        bind = "0.0.0.0:8081"
        wsgi_app = "server:app"
    kind: ConfigMap
    metadata:
      labels:
        appVersion: 0.1.0
        chart: groundx-0.1.0
        heritage: Helm
        version: 0.1.0
      name: workspace-gunicorn-conf-py-map
      namespace: eyelevel
  12: |
    apiVersion: v1
    data:
      supervisord.conf: |
        [supervisord]
        nodaemon=true
        logfile=/dev/null

        [program:celery_worker_1]
        command=celery -A celery_app.app worker -n %(ENV_POD_NAME)s-w1 --loglevel=INFO --concurrency=2 --queues=provision_queue --prefetch-multiplier=1 --max-tasks-per-child=100
        environment=
          CELERY_WORKER_NAME="%(ENV_POD_NAME)s-w1",
          LOCAL="0",
          PYTHONUNBUFFERED="1"
        autostart=true
        autorestart=true
        stdout_logfile=/dev/stdout
        stdout_logfile_maxbytes=0
        stderr_logfile=/dev/stderr
        stderr_logfile_maxbytes=0
    kind: ConfigMap
    metadata:
      labels:
        appVersion: 0.1.0
        chart: groundx-0.1.0
        heritage: Helm
        version: 0.1.0
      name: workspace-provision-supervisord-conf-map
      namespace: eyelevel
