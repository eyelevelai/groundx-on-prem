  10: |
    apiVersion: v1
    data:
      config.py: |
        from pathlib import Path

        from settings import Settings


        settings = Settings(
            allowed_commands="go,npm,pytest,python,node,git",
            celery_broker_url="redis://cache.eyelevel.svc.cluster.local:6379/0",
            celery_global_keyprefix="{workspace}",
            celery_result_backend="redis://cache.eyelevel.svc.cluster.local:6379/0",
            celery_task_always_eager=False,
            celery_task_soft_time_limit_seconds=900,
            command_timeout_seconds=300,
            git_provider="github",
            github_api_base_url="https://github.enterprise.example/api/v3",
            github_app_id="12345",
            github_app_installation_id="67890",
            github_app_private_key_path="/var/run/secrets/workspace/github/private-key.pem",
            github_app_private_key_pem="",
            github_token_ttl_seconds=1800,
            gitlab_api_base_url="https://gitlab.com/api/v4",
            gitlab_token="",
            gitlab_token_path="",
            managed_repo_name_prefix="workspace",
            managed_repo_owner="",
            managed_repo_visibility="private",
            mysql_connect_timeout_seconds=10,
            mysql_database="eyelevel",
            mysql_host="db-cluster-haproxy.eyelevel.svc.cluster.local",
            mysql_password="",
            mysql_port=3306,
            mysql_username="",
            publish_dry_run=False,
            runner_token="test-runner-token",
            service="workspace",
            workspace_min_free_bytes=0,
            workspace_min_free_percent=0,
            workspace_root=Path("/tmp/workspaces"),
        )
    kind: ConfigMap
    metadata:
      labels:
        appVersion: 0.1.0
        chart: groundx-0.1.0
        heritage: Helm
        version: 0.1.0
      name: workspace-config-py-map
      namespace: eyelevel
'enabled: workspace gitlab publish config':
  1: |
    apiVersion: apps/v1
    kind: Deployment
    metadata:
      labels:
        app: workspace-api
        appVersion: 0.1.0
        chart: groundx-0.1.0
        heritage: Helm
        version: 0.1.0
      name: workspace-api
      namespace: eyelevel
    spec:
      replicas: 1
      selector:
        matchLabels:
          app: workspace-api
      template:
        metadata:
          annotations:
            config-hash: 1bc77e04c2d45f8fef095a11d4e21983bf88235a0b9c0a4e7fabba5ebaa4c98c
            gunicorn-conf-hash: 310959745157fba9940d2f522881a1d73d439c9e733e1c4590626f021e7772ed
          labels:
            app: workspace-api
        spec:
          affinity:
            nodeAffinity:
              requiredDuringSchedulingIgnoredDuringExecution:
                nodeSelectorTerms:
                  - matchExpressions:
                      - key: node
                        operator: In
                        values:
                          - eyelevel-cpu-only
                  - matchExpressions:
                      - key: eyelevel_node
                        operator: In
                        values:
                          - eyelevel-cpu-only
          containers:
            - command:
                - /bin/bash
                - -c
                - |
                  export PYTHONPATH=/app:$PYTHONPATH && LOCAL=0 gunicorn -c /app/gunicorn_conf.py --capture-output --enable-stdio-inheritance
              env:
                - name: POD_NAME
                  valueFrom:
                    fieldRef:
                      fieldPath: metadata.name
              envFrom:
                - secretRef:
                    name: workspace-secret
              image: public.ecr.aws/c9r4x6y5/eyelevel/workspace-runner:0.1.0
              imagePullPolicy: IfNotPresent
              livenessProbe:
                failureThreshold: 12
                httpGet:
                  path: /health
                  port: 8080
                initialDelaySeconds: 10
                periodSeconds: 30
              name: workspace-api
              ports:
                - containerPort: 8080
                  protocol: TCP
              readinessProbe:
                httpGet:
                  path: /health
                  port: 8080
                initialDelaySeconds: 10
                periodSeconds: 30
              resources:
                requests:
                  cpu: 100m
                  memory: 256Mi
              securityContext:
                allowPrivilegeEscalation: false
                capabilities:
                  drop:
                    - ALL
                runAsGroup: 1001
                runAsNonRoot: true
                runAsUser: 1001
                seccompProfile:
                  type: RuntimeDefault
              volumeMounts:
                - mountPath: /app/config.py
                  name: config-volume
                  subPath: config.py
                - mountPath: /app/gunicorn_conf.py
                  name: gunicorn-conf-volume
                  subPath: gunicorn_conf.py
                - mountPath: /tmp/workspaces
                  name: workspace-data
                - mountPath: /var/run/secrets/workspace/gitlab
                  name: workspace-gitlab-token
                  readOnly: true
              workingDir: /app
          initContainers:
            - command:
                - sh
                - -c
                - until nc -z cache.eyelevel.svc.cluster.local 6379; do echo waiting for cache; sleep 2; done
              image: public.ecr.aws/c9r4x6y5/eyelevel/busybox:1.0.0
              imagePullPolicy: IfNotPresent
              name: wait-for-cache
            - command:
                - sh
                - -c
                - until nc -z db-cluster-haproxy.eyelevel.svc.cluster.local 3306; do echo waiting for database; sleep 2; done
              image: public.ecr.aws/c9r4x6y5/eyelevel/busybox:1.0.0
              imagePullPolicy: IfNotPresent
              name: wait-for-database
          securityContext:
            fsGroup: 1001
            fsGroupChangePolicy: OnRootMismatch
            runAsGroup: 1001
            runAsNonRoot: true
            runAsUser: 1001
            seccompProfile:
              type: RuntimeDefault
          tolerations:
            - effect: NoSchedule
              key: node
              value: eyelevel-cpu-only
            - effect: NoSchedule
              key: eyelevel_node
              value: eyelevel-cpu-only
          volumes:
            - configMap:
                name: workspace-config-py-map
              name: config-volume
            - configMap:
                name: workspace-gunicorn-conf-py-map
              name: gunicorn-conf-volume
            - name: workspace-data
