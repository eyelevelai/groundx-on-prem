'enabled: workspace':
  1: |
    apiVersion: apps/v1
    kind: Deployment
    metadata:
      labels:
        app: workspace-api
        appVersion: 0.1.0
        chart: groundx-0.1.0
        heritage: Helm
        version: 0.1.0
      name: workspace-api
      namespace: eyelevel
    spec:
      replicas: 1
      selector:
        matchLabels:
          app: workspace-api
      template:
        metadata:
          annotations:
            config-hash: 080672404770f3dfcbbbe0c2f8e03189082766e00c58f583fe2298989513f835
            gunicorn-conf-hash: 7b77a5ecbb71e70922f104c678cbaf4ce20a98b86db5735dab4924809990de45
            workspace.groundx.ai/component: api
          labels:
            app: workspace-api
            workspace.groundx.ai/tier: api
        spec:
          affinity:
            nodeAffinity:
              requiredDuringSchedulingIgnoredDuringExecution:
                nodeSelectorTerms:
                  - matchExpressions:
                      - key: node
                        operator: In
                        values:
                          - eyelevel-cpu-only
                  - matchExpressions:
                      - key: eyelevel_node
                        operator: In
                        values:
                          - eyelevel-cpu-only
          containers:
            - command:
                - /bin/bash
                - -c
                - |
                  export PYTHONPATH=/app:$PYTHONPATH && LOCAL=0 gunicorn -c /app/gunicorn_conf.py --capture-output --enable-stdio-inheritance
              env:
                - name: POD_NAME
                  valueFrom:
                    fieldRef:
                      fieldPath: metadata.name
              envFrom:
                - secretRef:
                    name: workspace-secret
              image: public.ecr.aws/c9r4x6y5/eyelevel/workspace-runner:0.1.0
              imagePullPolicy: Always
              livenessProbe:
                failureThreshold: 12
                httpGet:
                  path: /health
                  port: 8081
                initialDelaySeconds: 10
                periodSeconds: 30
              name: workspace-api
              ports:
                - containerPort: 8081
                  protocol: TCP
              readinessProbe:
                httpGet:
                  path: /health
                  port: 8081
                initialDelaySeconds: 10
                periodSeconds: 30
              resources:
                requests:
                  cpu: 50m
                  memory: 128Mi
              securityContext:
                allowPrivilegeEscalation: false
              volumeMounts:
                - mountPath: /app/config.py
                  name: config-volume
                  subPath: config.py
                - mountPath: /app/gunicorn_conf.py
                  name: gunicorn-conf-volume
                  subPath: gunicorn_conf.py
                - mountPath: /mnt/workspaces
                  name: workspace-data
              workingDir: /app
          initContainers:
            - command:
                - sh
                - -c
                - until nc -z cache.eyelevel.svc.cluster.local 6379; do echo waiting for cache; sleep 2; done
              image: public.ecr.aws/c9r4x6y5/eyelevel/busybox:1.0.0
              imagePullPolicy: IfNotPresent
              name: wait-for-cache
            - command:
                - sh
                - -c
                - until nc -z db-cluster-haproxy.eyelevel.svc.cluster.local 3306; do echo waiting for database; sleep 2; done
              image: public.ecr.aws/c9r4x6y5/eyelevel/busybox:1.0.0
              imagePullPolicy: IfNotPresent
              name: wait-for-database
          nodeSelector:
            groundx.ai/pool: api
          securityContext:
            fsGroup: 1001
            fsGroupChangePolicy: OnRootMismatch
            runAsGroup: 1001
            runAsNonRoot: true
            runAsUser: 1001
            seccompProfile:
              type: RuntimeDefault
          serviceAccountName: workspace-api-service-account
          tolerations:
            - effect: NoSchedule
              key: dedicated
              operator: Equal
              value: workspace
          volumes:
            - configMap:
                name: workspace-config-py-map
              name: config-volume
            - configMap:
                name: workspace-gunicorn-conf-py-map
              name: gunicorn-conf-volume
            - name: workspace-data
              persistentVolumeClaim:
                claimName: workspace-test-data
  2: |
    apiVersion: v1
    kind: Service
    metadata:
      labels:
        app: workspace-api
      name: workspace-api
      namespace: eyelevel
    spec:
      ports:
        - port: 80
          protocol: TCP
          targetPort: 8081
      selector:
        app: workspace-api
      type: ClusterIP
  3: |
    apiVersion: v1
    kind: PersistentVolumeClaim
    metadata:
      labels:
        app: workspace-api
      name: workspace-test-data
      namespace: eyelevel
    spec:
      accessModes:
        - ReadWriteMany
      resources:
        requests:
          storage: 25Gi
      storageClassName: efs-sc
  4: |
    apiVersion: apps/v1
    kind: Deployment
    metadata:
      labels:
        app: workspace-cleanup
        appVersion: 0.1.0
        chart: groundx-0.1.0
        heritage: Helm
        version: 0.1.0
      name: workspace-cleanup
      namespace: eyelevel
    spec:
      replicas: 1
      selector:
        matchLabels:
          app: workspace-cleanup
      template:
        metadata:
          annotations:
            config-hash: 080672404770f3dfcbbbe0c2f8e03189082766e00c58f583fe2298989513f835
            supervisord-hash: 6a2bc1f5f82dea1b2b37b20c4223b657306ca52eb46ad088ec48f1eac528dd86
          labels:
            app: workspace-cleanup
        spec:
          affinity:
            nodeAffinity:
              requiredDuringSchedulingIgnoredDuringExecution:
                nodeSelectorTerms:
                  - matchExpressions:
                      - key: node
                        operator: In
                        values:
                          - eyelevel-cpu-only
                  - matchExpressions:
                      - key: eyelevel_node
                        operator: In
                        values:
                          - eyelevel-cpu-only
          containers:
            - command:
                - /bin/sh
                - -c
                - |
                  export PYTHONPATH=/app && supervisord -c /app/supervisord.conf
              env:
                - name: POD_NAME
                  valueFrom:
                    fieldRef:
                      fieldPath: metadata.name
              envFrom:
                - secretRef:
                    name: workspace-secret
              image: public.ecr.aws/c9r4x6y5/eyelevel/workspace-runner:0.1.0
              imagePullPolicy: Always
              livenessProbe:
                exec:
                  command:
                    - /bin/sh
                    - -c
                    - ps aux | grep 'celery_app.app' | grep -v grep || exit 1
                initialDelaySeconds: 30
                periodSeconds: 30
              name: workspace-cleanup
              readinessProbe:
                exec:
                  command:
                    - /bin/sh
                    - -c
                    - ps aux | grep 'celery_app.app' | grep -v grep || exit 1
                initialDelaySeconds: 10
                periodSeconds: 30
              securityContext:
                allowPrivilegeEscalation: false
                capabilities:
                  drop:
                    - ALL
                runAsGroup: 1001
                runAsNonRoot: true
                runAsUser: 1001
                seccompProfile:
                  type: RuntimeDefault
              volumeMounts:
                - mountPath: /app/config.py
                  name: config-volume
                  subPath: config.py
                - mountPath: /app/supervisord.conf
                  name: supervisord-volume
                  subPath: supervisord.conf
                - mountPath: /mnt/workspaces
                  name: workspace-data
              workingDir: /app
          initContainers:
            - command:
                - sh
                - -c
                - until nc -z cache.eyelevel.svc.cluster.local 6379; do echo waiting for cache; sleep 2; done
              image: public.ecr.aws/c9r4x6y5/eyelevel/busybox:1.0.0
              imagePullPolicy: IfNotPresent
              name: wait-for-cache
            - command:
                - sh
                - -c
                - until nc -z db-cluster-haproxy.eyelevel.svc.cluster.local 3306; do echo waiting for database; sleep 2; done
              image: public.ecr.aws/c9r4x6y5/eyelevel/busybox:1.0.0
              imagePullPolicy: IfNotPresent
              name: wait-for-database
          securityContext:
            fsGroup: 1001
            fsGroupChangePolicy: OnRootMismatch
            runAsGroup: 1001
            runAsNonRoot: true
            runAsUser: 1001
            seccompProfile:
              type: RuntimeDefault
          tolerations:
            - effect: NoSchedule
              key: node
              value: eyelevel-cpu-only
            - effect: NoSchedule
              key: eyelevel_node
              value: eyelevel-cpu-only
          volumes:
            - configMap:
                name: workspace-config-py-map
              name: config-volume
            - configMap:
                name: workspace-cleanup-supervisord-conf-map
              name: supervisord-volume
            - name: workspace-data
              persistentVolumeClaim:
                claimName: workspace-test-data
