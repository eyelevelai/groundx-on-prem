'enabled: workspace api ingress':
  1: |
    apiVersion: networking.k8s.io/v1
    kind: Ingress
    metadata:
      labels:
        appVersion: 0.1.0
        chart: groundx-0.1.0
        heritage: Helm
        version: 0.1.0
      name: workspace
      namespace: eyelevel
    spec:
      ingressClassName: nginx
      rules:
        - host: workspace.example.com
          http:
            paths:
              - backend:
                  service:
                    name: workspace
                    port:
                      number: 80
                path: /workspace
                pathType: ImplementationSpecific
'enabled: workspace github pem fallback secret':
  1: |
    apiVersion: apps/v1
    kind: Deployment
    metadata:
      labels:
        app: workspace-api
        appVersion: 0.1.0
        chart: groundx-0.1.0
        heritage: Helm
        version: 0.1.0
      name: workspace-api
      namespace: eyelevel
    spec:
      replicas: 1
      selector:
        matchLabels:
          app: workspace-api
      template:
        metadata:
          annotations:
            config-hash: 6276c706f9d40868fa9b3704840e7e40b6d46316037b1ab7c0cde910f282efdf
            gunicorn-conf-hash: 310959745157fba9940d2f522881a1d73d439c9e733e1c4590626f021e7772ed
          labels:
            app: workspace-api
        spec:
          affinity:
            nodeAffinity:
              requiredDuringSchedulingIgnoredDuringExecution:
                nodeSelectorTerms:
                  - matchExpressions:
                      - key: node
                        operator: In
                        values:
                          - eyelevel-cpu-only
                  - matchExpressions:
                      - key: eyelevel_node
                        operator: In
                        values:
                          - eyelevel-cpu-only
          containers:
            - command:
                - /bin/bash
                - -c
                - |
                  export PYTHONPATH=/app:$PYTHONPATH && LOCAL=0 gunicorn -c /app/gunicorn_conf.py --capture-output --enable-stdio-inheritance
              env:
                - name: POD_NAME
                  valueFrom:
                    fieldRef:
                      fieldPath: metadata.name
              envFrom:
                - secretRef:
                    name: workspace-github-secret
                - secretRef:
                    name: workspace-secret
              image: public.ecr.aws/c9r4x6y5/eyelevel/workspace-runner:0.1.0
              imagePullPolicy: IfNotPresent
              livenessProbe:
                failureThreshold: 12
                httpGet:
                  path: /health
                  port: 8080
                initialDelaySeconds: 10
                periodSeconds: 30
              name: workspace-api
              ports:
                - containerPort: 8080
                  protocol: TCP
              readinessProbe:
                httpGet:
                  path: /health
                  port: 8080
                initialDelaySeconds: 10
                periodSeconds: 30
              resources:
                requests:
                  cpu: 100m
                  memory: 256Mi
              securityContext:
                allowPrivilegeEscalation: false
                capabilities:
                  drop:
                    - ALL
                runAsGroup: 1001
                runAsNonRoot: true
                runAsUser: 1001
                seccompProfile:
                  type: RuntimeDefault
              volumeMounts:
                - mountPath: /app/config.py
                  name: config-volume
                  subPath: config.py
                - mountPath: /app/gunicorn_conf.py
                  name: gunicorn-conf-volume
                  subPath: gunicorn_conf.py
                - mountPath: /tmp/workspaces
                  name: workspace-data
              workingDir: /app
          initContainers:
            - command:
                - sh
                - -c
                - until nc -z cache.eyelevel.svc.cluster.local 6379; do echo waiting for cache; sleep 2; done
              image: public.ecr.aws/c9r4x6y5/eyelevel/busybox:1.0.0
              imagePullPolicy: IfNotPresent
              name: wait-for-cache
            - command:
                - sh
                - -c
                - until nc -z db-cluster-haproxy.eyelevel.svc.cluster.local 3306; do echo waiting for database; sleep 2; done
              image: public.ecr.aws/c9r4x6y5/eyelevel/busybox:1.0.0
              imagePullPolicy: IfNotPresent
              name: wait-for-database
          securityContext:
            fsGroup: 1001
            fsGroupChangePolicy: OnRootMismatch
            runAsGroup: 1001
            runAsNonRoot: true
            runAsUser: 1001
            seccompProfile:
              type: RuntimeDefault
          tolerations:
            - effect: NoSchedule
              key: node
              value: eyelevel-cpu-only
            - effect: NoSchedule
              key: eyelevel_node
              value: eyelevel-cpu-only
          volumes:
            - configMap:
                name: workspace-config-py-map
              name: config-volume
            - configMap:
                name: workspace-gunicorn-conf-py-map
              name: gunicorn-conf-volume
            - name: workspace-data
              persistentVolumeClaim:
                claimName: workspace-data
  2: |
    apiVersion: v1
    kind: Service
    metadata:
      labels:
        app: workspace-api
      name: workspace-api
      namespace: eyelevel
    spec:
      ports:
        - port: 80
          protocol: TCP
          targetPort: 8080
      selector:
        app: workspace-api
      type: ClusterIP
  3: |
    apiVersion: v1
    kind: PersistentVolumeClaim
    metadata:
      labels:
        app: workspace-api
      name: workspace-data
      namespace: eyelevel
    spec:
      accessModes:
        - ReadWriteMany
      resources:
        requests:
          storage: 20Gi
      storageClassName: eyelevel-pv
  4: |
